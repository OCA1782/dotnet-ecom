{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "Database": {
    "Provider": "PostgreSQL"
  },
  "ConnectionStrings": {
    "DefaultConnection": "__STAGING_DB_CONNECTION__",
    "Redis": "__STAGING_REDIS__"
  },
  "Jwt": {
    "Key": "__STAGING_JWT_KEY__",
    "Issuer": "ecom-staging",
    "Audience": "ecom-staging-client",
    "ExpiresInMinutes": "60"
  },
  "Email": {
    "SmtpHost": "__SMTP_HOST__",
    "SmtpPort": "587",
    "Username": "__SMTP_USER__",
    "Password": "__SMTP_PASS__",
    "FromAddress": "__FROM_EMAIL__",
    "FromName": "Ecom Staging"
  },
  "RabbitMQ": {
    "Host": "__RABBITMQ_HOST__",
    "Username": "guest",
    "Password": "guest"
  }
}
