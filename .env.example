# ─────────────────────────────────────────────
# Ecom Docker Compose — Ortam Değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# .env dosyasını GİT'E EKLEMEYİN
# ─────────────────────────────────────────────

# ── SQL Server ────────────────────────────────
SA_PASSWORD=REDACTED_SA_PASSWORD
MSSQL_MEMORY_LIMIT_MB=1500

# ── JWT ───────────────────────────────────────
# En az 32 karakter, güçlü rastgele string kullanın
JWT_KEY=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_AT_LEAST_32_CHARS

# ── Seed (ilk kurulum admin hesabı) ───────────
SEED_ADMIN_EMAIL=admin@ecom.com
SEED_ADMIN_PASSWORD=REDACTED_ADMIN_PASSWORD

# ── Lisans ────────────────────────────────────
# appsettings.Development.json'daki License değeri
ECOM_LICENSE=

# ── API ───────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# Sunucu IP veya domain (örn: http://178.105.230.111:5124)
API_PUBLIC_URL=http://localhost:5124

# ── Frontend ──────────────────────────────────
# Build-time baked — sunucu IP veya domain olmalı
NEXT_PUBLIC_API_URL=http://localhost:5124

# ── CORS ──────────────────────────────────────
ALLOWED_ORIGIN_0=http://localhost:3000
ALLOWED_ORIGIN_1=http://localhost:3001

# ── RabbitMQ ──────────────────────────────────
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
