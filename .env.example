# ─────────────────────────────────────────────
# Ecom Docker Compose — Ortam Değişkenleri
# Bu dosyayı kopyalayın: cp .env.example .env
# .env dosyasını GİT'E EKLEMEYİN
# ─────────────────────────────────────────────

# ── SQL Server ────────────────────────────────
SA_PASSWORD=CHANGE_ME_STRONG_SQL_PASSWORD
MSSQL_MEMORY_LIMIT_MB=1500

# ── JWT ───────────────────────────────────────
# En az 32 karakter, güçlü rastgele string kullanın
JWT_KEY=CHANGE_ME_STRONG_JWT_SECRET_AT_LEAST_32_CHARS

# ── Seed (ilk kurulum admin hesabı) ───────────
SEED_ADMIN_EMAIL=admin@ecom.com
SEED_ADMIN_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# ── Lisans ────────────────────────────────────
# RSA-2048 lisans token (Lisans Üretici'den üretilir)
ECOM_LICENSE=
# RSA public key — SPKI DER base64 formatı (PEM başlıkları olmadan)
# Kaynak kodda saklanmaz. Lisans Üretici > Anahtar Çifti Üret ile oluşturulur.
ECOM_PUBLIC_KEY=
# Online aktivasyon URL (opsiyonel — boş bırakılırsa devre dışı)
# POST { hash, hostname } → 200 OK (yetkili) | 403 (yetkisiz)
LICENSE_ACTIVATION_URL=

# ── API ───────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
API_PUBLIC_URL=http://localhost:5124

# ── Frontend ──────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5124

# ── CORS ──────────────────────────────────────
ALLOWED_ORIGIN_0=http://localhost:3000
ALLOWED_ORIGIN_1=http://localhost:3001

# ── RabbitMQ ──────────────────────────────────
RABBITMQ_USERNAME=CHANGE_ME_RABBITMQ_USERNAME
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_RABBITMQ_PASSWORD

# ── GitHub (opsiyonel — docs sync için) ───────
GITHUB_TOKEN=

# ── Cloudinary (opsiyonel — görsel yükleme) ───
CLOUDINARY_URL=

# ── Local Storage Public URL ───────────────────
# Cloudinary kullanmıyorsanız, yüklenen görsellerin public URL'si buraya girilmeli.
# Örn: http://178.105.230.111:5124  veya  https://api.yourdomain.com
# Boş bırakılırsa X-Forwarded-Host header'ından otomatik alınmaya çalışılır.
STORAGE_PUBLIC_BASE_URL=

# ── Lisans Servisi (dotnet-ecom-licence) ───────
# Ecom API ↔ EcomLicence servisi arası kimlik doğrulama anahtarı
# En az 32 karakter güçlü rastgele string (python: secrets.token_hex(32))
LICENCE_SERVICE_KEY=CHANGE_ME_STRONG_LICENCE_SERVICE_KEY

# ── Deploy SSH (deploy/*.py scriptleri için) ──
# Bu değerleri .env dosyanıza ekleyin, kesinlikle koda yazmayın
DEPLOY_SSH_HOST=CHANGE_ME_SERVER_IP
DEPLOY_SSH_USER=CHANGE_ME_SSH_USER
DEPLOY_SSH_PASSWORD=CHANGE_ME_SSH_PASSWORD
